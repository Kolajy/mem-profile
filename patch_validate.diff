fn validate_file_for_reading(path: &str) -> std::io::Result<()> {
    let meta = fs::metadata(path)?;
    if !meta.is_file() {
        return Err(std::io::Error::new(
            std::io::ErrorKind::InvalidInput,
            format!("{} is not a regular file", path),
        ));
    }
    let max_size = 256 * 1024 * 1024; // 256 MB
